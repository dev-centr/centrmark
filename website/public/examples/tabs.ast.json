{"hasFrontmatter":true,"frontmatter":{"raw":"title \"Tabs (multi-language and multi-tool)\"\nauthor {\n  name \"CentrMark Team\"\n  role \"Documentation\"\n}\ntags \"example\", \"tabs\", \"code\"\nversion 1.0.0\nstatus \"Final\"\n"},"blocks":[{"kind":"Heading","hasFrontmatter":false,"level":1,"inlines":[{"kind":"Text","text":"Tabs (multi-language and multi-tool)"}]},{"kind":"Paragraph","hasFrontmatter":false,"inlines":[{"kind":"Text","text":"CentrMarkΓÇÖs feature for ΓÇ£multi-paneΓÇ¥ technical writing is the "},{"kind":"CodeSpan","text":"::: tabs"},{"kind":"Text","text":" block directive. It groups multiple representations of the same underlying idea (for example, the same API call) under one stable section, so readers can compare variants without losing context."}]},{"kind":"Paragraph","hasFrontmatter":false,"inlines":[{"kind":"Text","text":"It supports both multi-language and multi-tool documentation."}]},{"kind":"Paragraph","hasFrontmatter":false,"inlines":[{"kind":"Text","text":"For multi-language, each tab shows the same idea in a different implementation language."}]},{"kind":"Paragraph","hasFrontmatter":false,"inlines":[{"kind":"Text","text":"For multi-tool, each tab shows the same idea in a different tool/SDK/client."}]},{"kind":"Paragraph","hasFrontmatter":false,"inlines":[{"kind":"Text","text":"Use-case: present the same request using different clients."}]},{"kind":"Heading","hasFrontmatter":false,"level":2,"inlines":[{"kind":"Text","text":"Multi-Language Code References"}]},{"kind":"BlockDirective","hasFrontmatter":false,"fenceLen":4,"name":"tabs","propsRaw":"sync=\"variant\" align=\"center\"","body":[{"kind":"BlockDirective","hasFrontmatter":false,"fenceLen":3,"name":"tab","propsRaw":"label=\"curl\"","body":[{"kind":"CodeBlock","hasFrontmatter":false,"language":"bash","code":"curl -X GET https://api.example.com/status\n"}]},{"kind":"BlockDirective","hasFrontmatter":false,"fenceLen":3,"name":"tab","propsRaw":"label=\"httpie\"","body":[{"kind":"CodeBlock","hasFrontmatter":false,"language":"bash","code":"http GET https://api.example.com/status\n"}]},{"kind":"BlockDirective","hasFrontmatter":false,"fenceLen":3,"name":"tab","propsRaw":"label=\"Python (requests)\"","body":[{"kind":"CodeBlock","hasFrontmatter":false,"language":"python","code":"import requests\nres = requests.get(\"https://api.example.com/status\")\n"}]},{"kind":"BlockDirective","hasFrontmatter":false,"fenceLen":3,"name":"tab","propsRaw":"label=\"Go (net/http)\"","body":[{"kind":"CodeBlock","hasFrontmatter":false,"language":"go","code":"resp, err := http.Get(\"https://api.example.com/status\")\n"}]}]}]}